  "image_index": [
    {
      "key": "wide-canyon-overview",
      "frame_id": "frame-01",
      "frame_index": 1,
      "description": "Sheet 1, image 1. Opening frame. Wide canyon panorama at golden hour; visual mass in the canyon mid-ground. Sky and flat foreground are the quiet zones. Bottom gradient darkens the foreground for the headline stack. Full text treatment: eyebrow location tag (#FFFFFF per color-notes), large TATACOA headline, two-sentence geographic caption anchoring the series."
    },
    {
      "key": "eroded-channels-closeup",
      "frame_id": "frame-02",
      "frame_index": 2,
      "description": "Sheet 1, image 4. Silent frame. Close-up of eroded red earth channels — texture fills the frame edge to edge with no quiet zone. No overlay, no text, no shapes. The raw surface is presented clean. Editorial breath after the opening statement."
    },
    {
      "key": "columnar-formations",
      "frame_id": "frame-03",
      "frame_index": 3,
      "description": "Sheet 1, image 5. Geological label frame. Tall eroded columns dominate center and left; sky at the upper portion is the quiet zone. Top gradient subtly darkens sky for the headline. Focal point lowered to y_pct 60 to keep column tops in frame. Headline only: SEDIMENTOS DEL MIOCENO (#FFFFFF per color-notes — warm-ochre background at medium luminance requires maximum contrast)."
    },
    {
      "key": "mesa-formation",
      "frame_id": "frame-04",
      "frame_index": 4,
      "description": "Sheet 1, image 6. Silent frame. Mesa or isolated formation — the geological chapter's closing image. No overlay, no text, no shapes. Second editorial breath before the series transitions to life."
    },
    {
      "key": "cacti-canyon-wall",
      "frame_id": "frame-05",
      "frame_index": 5,
      "description": "Sheet 1, image 3. Flora transition frame. Clustered Melocactus and columnar cacti in the foreground against canyon walls. Eye enters at the nearest cactus and moves back to the formations. Bottom gradient; headline FLORA DEL DESIERTO plus single-sentence caption marks the thematic shift from geology to life."
    },
    {
      "key": "barrel-cactus-bloom",
      "frame_id": "frame-06",
      "frame_index": 6,
      "description": "Sheet 1, image 2. Life close-up. Barrel cactus with bloom at apex — the pink cephalium is the magnetic point and emotional beat of the series. Focal point y_pct 45 to keep the bloom in the upper frame. Headline only: MELOCACTUS, positioned near the canvas bottom to stay clear of the bloom."
    },
    {
      "key": "burrowing-owls",
      "frame_id": "frame-07",
      "frame_index": 7,
      "description": "Sheet 1, image 7. Conceptual payoff. Two burrowing owls in grass; their camouflage echoes the geological textures from frames 2–4. Text stays clear of both owl faces. Bottom gradient; headline ATHENE CUNICULARIA plus two-sentence caption connecting camouflage to the desert's color palette — the thematic resolution."
    },
    {
      "key": "desert-road",
      "frame_id": "frame-08",
      "frame_index": 8,
      "description": "Sheet 1, image 8. Closing frame. Wide road with a small figure in the distance — human scale restores proportion after the close-up frames. Eyebrow NEIVA · HUILA (#FFFFFF per color-notes — hazy sky at top-right without gradient requires maximum contrast) at top-right; CAMINO DEL DESIERTO headline at bottom-left. Quiet close."
    }
  ]
